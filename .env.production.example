# Copy to .env.production and replace every CHANGE_ME value.
NODE_ENV=production
HOST=0.0.0.0
PORT=8790

MUD_SERVICE_NAME=phyrex-world-engine
MUD_DATA_DIR=/data
MUD_WORLD_FILE=world.json
MUD_TEMPLATE_ID=cultivation_frontier
MUD_SEED_TICKS=10

# Required on first startup. Keep this value outside source control.
MUD_ADMIN_ID=admin
MUD_ADMIN_NAME=World Administrator
MUD_ADMIN_SECRET=CHANGE_ME_USE_AT_LEAST_20_RANDOM_CHARACTERS
MUD_ROTATE_ADMIN_SECRET=false

# disabled: nobody can register; admin: GM/admin creates accounts; open: public player registration.
MUD_REGISTRATION_POLICY=admin
MUD_REQUIRE_AUTH=true
MUD_REQUIRE_CREDENTIALS=true
MUD_SESSION_TTL_TICKS=100000

# Leave empty for same-origin only. Comma-separate exact origins when using a separate frontend.
MUD_CORS_ORIGINS=
MUD_TRUST_PROXY=false
MUD_MAX_BODY_BYTES=262144

MUD_AUTO_LOOP=true
MUD_LOOP_INTERVAL_MS=1000
MUD_TICKS_PER_CYCLE=1
MUD_AUTOSAVE_EVERY_TICKS=25
MUD_AUTOSAVE_FILE=autosave/world.json
MUD_LOOP_IMMEDIATE=false
MUD_STOP_ON_ERROR=true
MUD_SHUTDOWN_SAVE=true
MUD_SHUTDOWN_TIMEOUT_MS=10000

MUD_RATE_WINDOW_MS=60000
MUD_RATE_GENERAL_MAX=600
MUD_RATE_AUTH_MAX=20
MUD_RATE_REGISTRATION_MAX=5
